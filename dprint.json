{
  "incremental": true,
  "lineWidth": 100,
  "markdown": {
    "lineWidth": 100,
    "textWrap": "always"
  },
  "json": {
    "indentWidth": 2
  },
  "toml": {
    "indentWidth": 2
  },
  "includes": [
    "**/*.{md,json,toml,yaml,yml}"
  ],
  "excludes": [
    "target",
    "Cargo.lock",
    "**/parser.rs"
  ],
  "plugins": [
    "https://plugins.dprint.dev/markdown-0.17.8.wasm",
    "https://plugins.dprint.dev/json-0.19.4.wasm",
    "https://plugins.dprint.dev/toml-0.6.3.wasm"
  ]
}
